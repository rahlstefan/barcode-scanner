{
  "expo": {
    "name": "BarcodeScanner",
    "slug": "barcode-scanner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": false,
      "bundleIdentifier": "com.barcode.scanner",
      "requireFullScreen": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Необходимо для сканирования кодов",
        "UIRequiredDeviceCapabilities": [
          "camera"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-camera",
      [
        "expo-modules-autolinking",
        {
          "modules": [
            "./modules/barcode-detector"
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "barcode-scanner"
      }
    }
  }
}
