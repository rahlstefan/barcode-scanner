{
  "expo": {
    "name": "BarcodeScanner",
    "slug": "barcode-scanner",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.barcode.scanner",
      "infoPlist": {
        "NSCameraUsageDescription": "Доступ к камере необходим для сканирования штрих-кодов",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.barcode.scanner",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "assetBundlePatterns": [
      "assets/models/*"
    ],
    "plugins": [
      [
        "expo-asset",
        {
          "assets": [
            "assets/models/yolo.tflite"
          ]
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Доступ к камере необходим для сканирования штрих-кодов",
          "enableCodeScanner": false,
          "enableLocation": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "57090696-9519-4741-8d78-752b2d37c9e4"
      }
    },
    "owner": "tiltmachinegun"
  }
}
